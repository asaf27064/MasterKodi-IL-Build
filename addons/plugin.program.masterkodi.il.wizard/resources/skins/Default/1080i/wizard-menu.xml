<?xml version="1.0" encoding="UTF-8"?>
<!-- MasterKodi IL Wizard - unified menu window.
     Right (RTL): the menu list, each row title + subtitle + icon.
     Left: branded panel + a BIG description of the focused row.
     Generic fonts + own white.png so it renders identically on any skin. -->
<window type="dialog" id="3101">
    <defaultcontrol always="true">100</defaultcontrol>
    <controls>
        <!-- full-screen dim + brand fanart -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="F0000000">white.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="22FFFFFF">fanart.jpg</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <!-- gold top accent bar -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>6</height>
            <texture colordiffuse="FFFFD700">white.png</texture>
        </control>

        <!-- header: logo + title (right aligned for RTL) -->
        <control type="image">
            <right>70</right><top>48</top><width>70</width><height>70</height>
            <texture>logo.png</texture>
            <aspectratio>keep</aspectratio>
        </control>
        <control type="label">
            <left>85</left><top>55</top><width>1610</width><height>60</height>
            <align>right</align>
            <font>font14</font>
            <textcolor>FFFFD700</textcolor>
            <label>$INFO[Window.Property(heading)]</label>
        </control>

        <!-- LEFT: big detail panel for the focused row -->
        <control type="image">
            <left>110</left><top>190</top><width>1060</width><height>720</height>
            <texture colordiffuse="CC14161B">white.png</texture>
        </control>
        <control type="image">
            <left>150</left><top>250</top><width>150</width><height>150</height>
            <texture>$INFO[Container(100).ListItem.Icon]</texture>
            <aspectratio>keep</aspectratio>
        </control>
        <control type="label">
            <left>150</left><top>430</top><width>980</width><height>70</height>
            <align>right</align>
            <font>font14</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>$INFO[Container(100).ListItem.Label]</label>
        </control>
        <control type="textbox">
            <left>150</left><top>520</top><width>980</width><height>360</height>
            <align>right</align>
            <font>font12</font>
            <textcolor>FFC8C8C8</textcolor>
            <label>$INFO[Container(100).ListItem.Label2]</label>
        </control>

        <!-- RIGHT: the menu list -->
        <control type="list" id="100">
            <left>1210</left><top>190</top><width>600</width><height>760</height>
            <onleft>100</onleft><onright>100</onright><onup>100</onup><ondown>100</ondown>
            <pagecontrol>-</pagecontrol>
            <scrolltime tween="cubic" easing="out">220</scrolltime>
            <orientation>vertical</orientation>
            <itemlayout height="96" width="600">
                <control type="image">
                    <left>0</left><top>4</top><width>600</width><height>88</height>
                    <texture colordiffuse="CC1C1F27">white.png</texture>
                </control>
                <control type="image">
                    <right>16</right><top>20</top><width>56</width><height>56</height>
                    <texture>$INFO[ListItem.Icon]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
                <control type="label">
                    <left>20</left><top>10</top><width>500</width><height>44</height>
                    <align>right</align><font>font13</font>
                    <textcolor>FFE8E8E8</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <left>20</left><top>52</top><width>500</width><height>34</height>
                    <align>right</align><font>font10</font>
                    <textcolor>FF8A8A8A</textcolor>
                    <label>$INFO[ListItem.Label2]</label>
                </control>
            </itemlayout>
            <focusedlayout height="96" width="600">
                <control type="image">
                    <left>0</left><top>4</top><width>600</width><height>88</height>
                    <texture colordiffuse="FF2E5A8E">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>4</top><width>6</width><height>88</height>
                    <texture colordiffuse="FFFFD700">white.png</texture>
                </control>
                <control type="image">
                    <right>16</right><top>20</top><width>56</width><height>56</height>
                    <texture>$INFO[ListItem.Icon]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
                <control type="label">
                    <left>20</left><top>10</top><width>500</width><height>44</height>
                    <align>right</align><font>font13</font>
                    <textcolor>FFFFD700</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <left>20</left><top>52</top><width>500</width><height>34</height>
                    <align>right</align><font>font10</font>
                    <textcolor>FFDDDDDD</textcolor>
                    <label>$INFO[ListItem.Label2]</label>
                </control>
            </focusedlayout>
        </control>

        <!-- footer hint -->
        <control type="label">
            <left>110</left><bottom>40</bottom><width>1700</width><height>36</height>
            <align>center</align><font>font10</font>
            <textcolor>FF888888</textcolor>
            <label>OK לבחירה  ·  Back ליציאה</label>
        </control>
    </controls>
</window>
