<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <category label="עדכונים">
        <setting id="auto_update_check" type="bool" label="בדוק עדכונים בהפעלת Kodi" default="true" />
        <setting id="update_check_delay" type="slider" label="השהייה לפני בדיקת עדכונים (שניות)" default="15" range="5,5,60" option="int" />
        <setting type="lsep" label="כל הבילד מתעדכן אוטומטית מהמאניפסט (אימות SHA256, רק מה שהשתנה). אין צורך בהתקנות עברית נפרדות." />
        <setting type="sep" />
        <setting id="check_updates_now" type="action" label="בדוק עדכונים עכשיו" action="RunPlugin(plugin://plugin.program.masterkodi.il.wizard/?mode=check_updates)" option="close" />
    </category>
    <category label="התקנה">
        <setting id="keep_ask" type="bool" label="שאל מה לשמור בכל התקנה" default="true" />
        <setting type="lsep" label="כשכבוי: ההתקנה שומרת אוטומטית הכל (התחברויות, מפתח Gemini, צפייה ומועדפים) בלי לשאול. גם כשדלוק, החלון מדולג אם אין מה לשמור." />
    </category>
    <category label="גיבוי ושחזור">
        <setting id="backup_location" type="folder" label="מיקום גיבויים (מומלץ אחסון חיצוני כדי לשרוד התקנה מחדש)" default="" />
        <setting type="lsep" label="גיבוי שומר: מפתח Gemini, טוקנים של דבריד, הגדרות, מועדפים ומקורות" />
    </category>
    <category label="הבילד המותקן">
        <setting id="buildname" type="text" label="שם הבילד" default="" visible="true" enable="false" />
        <setting id="buildversion" type="text" label="גרסת הבילד" default="" visible="true" enable="false" />
        <setting id="installed_skin" type="text" label="סקין מותקן" default="" visible="true" enable="false" />
    </category>
    <category label="פנימי (מוסתר)">
        <setting id="skip_update_check" type="text" label="Skip next update check" default="false" visible="false" />
        <setting id="content_source" type="text" label="Content source (gears/pov)" default="gears" visible="false" />
    </category>
</settings>
