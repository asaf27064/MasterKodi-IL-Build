<?xml version="1.0" encoding="UTF-8"?>
<includes>

    <include name="SeasonalTheme">
        <control type="group">
            <visible>!Skin.HasSetting(SeasonalTheme.DisableLoop)</visible>
            <control type="group">
                <animation effect="slide" start="60,0" end="-60,0" time="10000" condition="true" reversible="false" pulse="true">Conditional</animation>
                <animation effect="fade" end="20" condition="true">Conditional</animation>
                <control type="image">
                    <texture flipx="true" flipy="true" colordiffuse="main_fg_70">special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/$PARAM[loop_file]</texture>
                    <width>2430</width>
                    <aspectratio>keep</aspectratio>
                    <animation effect="slide" time="30000" start="0,0" end="0,1080" condition="true" loop="true">Conditional</animation>
                </control>
                <control type="image">
                    <texture flipx="true" flipy="true" colordiffuse="main_fg_70">special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/$PARAM[loop_file]</texture>
                    <width>2430</width>
                    <aspectratio>keep</aspectratio>
                    <animation effect="slide" time="30000" start="0,-1080" end="0,0" condition="true" loop="true">Conditional</animation>
                </control>
            </control>

            <control type="group">
                <animation effect="slide" start="-60,0" end="60,0" time="10000" condition="true" reversible="false" pulse="true">Conditional</animation>
                <control type="image">
                    <texture colordiffuse="main_fg_70">special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/$PARAM[loop_file]</texture>
                    <width>2430</width>
                    <aspectratio>keep</aspectratio>
                    <animation effect="slide" time="16000" start="0,0" end="0,1080" condition="true" loop="true">Conditional</animation>
                </control>
                <control type="image">
                    <texture colordiffuse="main_fg_70">special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/$PARAM[loop_file]</texture>
                    <width>2430</width>
                    <aspectratio>keep</aspectratio>
                    <animation effect="slide" time="16000" start="0,-1080" end="0,0" condition="true" loop="true">Conditional</animation>
                </control>
            </control>
        </control>

        <control type="group">
            <visible>!Skin.String(SeasonalTheme.PropsDensity,Off)</visible>

            <control type="group">
                <control type="multiimage">
                    <posx>175</posx>
                    <posy>-120</posy>
                    <width>40</width>
                    <height>40</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>30000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="26000" delay="4000" reversible="false" />
                        <effect type="slide" start="-35,0" end="35,0" time="8300" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>525</posx>
                    <posy>-120</posy>
                    <width>83</width>
                    <height>108</height>
                    <aspectratio>center</aspectratio>
                    <timeperimage>34000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="22000" delay="12000" reversible="false" />
                        <effect type="slide" start="-65,0" end="65,0" time="9400" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>875</posx>
                    <posy>-120</posy>
                    <width>52</width>
                    <height>52</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>26000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="19000" delay="7000" reversible="false" />
                        <effect type="slide" start="-45,0" end="45,0" time="7300" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>1225</posx>
                    <posy>-120</posy>
                    <width>64</width>
                    <height>64</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>20000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="15000" delay="5000" reversible="false" />
                        <effect type="slide" start="-55,0" end="55,0" time="5700" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>1575</posx>
                    <posy>-120</posy>
                    <width>28</width>
                    <height>28</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>34000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="34000" reversible="false" />
                        <effect type="slide" start="-25,0" end="25,0" time="12300" pulse="true" reversible="false" />
                    </animation>
                </control>
            </control>

            <control type="group">
                <visible>Skin.String(SeasonalTheme.PropsDensity,High)</visible>

                <control type="multiimage">
                    <posx>350</posx>
                    <posy>-120</posy>
                    <width>52</width>
                    <height>52</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>16000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="16000" reversible="false" />
                        <effect type="slide" start="-45,0" end="45,0" time="6100" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>700</posx>
                    <posy>-120</posy>
                    <width>28</width>
                    <height>28</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>38000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="36000" delay="2000" reversible="false" />
                        <effect type="slide" start="-25,0" end="25,0" time="11100" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>1050</posx>
                    <posy>-120</posy>
                    <width>83</width>
                    <height>108</height>
                    <aspectratio>center</aspectratio>
                    <timeperimage>44000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="30000" delay="14000" reversible="false" />
                        <effect type="slide" start="-70,0" end="70,0" time="10500" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>1400</posx>
                    <posy>-120</posy>
                    <width>40</width>
                    <height>40</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>43000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="28000" delay="15000" reversible="false" />
                        <effect type="slide" start="-35,0" end="35,0" time="8900" pulse="true" reversible="false" />
                    </animation>
                </control>

                <control type="multiimage">
                    <posx>1750</posx>
                    <posy>-120</posy>
                    <width>64</width>
                    <height>64</height>
                    <aspectratio>keep</aspectratio>
                    <timeperimage>32000</timeperimage>
                    <fadetime>0</fadetime>
                    <randomize>true</randomize>
                    <imagepath>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/icons</imagepath>
                    <animation type="Conditional" condition="true" reversible="false" loop="true">
                        <effect type="slide" start="0,0" end="0,1250" time="21000" delay="11000" reversible="false" />
                        <effect type="slide" start="-45,0" end="45,0" time="7700" pulse="true" reversible="false" />
                    </animation>
                </control>
            </control>
        </control>

        <control type="group">
            <visible>!Skin.HasSetting(SeasonalTheme.DisableFlyBy)</visible>

            <control type="group">
                <posx>-350</posx>
                <control type="image">
                    <posy>320</posy>
                    <width>230</width>
                    <height>200</height>
                    <texture flipx="true">special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/$PARAM[flyby_file]</texture>
                    <aspectratio>center</aspectratio>
                    <include>SeasonalThemes_Animation_$PARAM[animation]_Right</include>
                    <animation type="Conditional" condition="true" loop="true">
                        <effect type="slide" start="0,0" end="2330,0" time="10000" delay="7500" condition="true">Conditional</effect>
                        <effect type="fade" start="100" end="100" time="17500" delay="17500" condition="true">Conditional</effect>
                    </animation>
                </control>
            </control>

            <control type="group">
                <posx>2000</posx>
                <control type="image">
                    <posy>520</posy>
                    <width>230</width>
                    <height>200</height>
                    <texture>special://skin/extras/backgrounds/holiday/$PARAM[theme_dir]/$PARAM[flyby_file]</texture>
                    <aspectratio>center</aspectratio>
                    <include>SeasonalThemes_Animation_$PARAM[animation]_Left</include>
                    <animation effect="slide" start="0,0" end="-2350,0" time="10000" delay="25000" loop="true" condition="true">Conditional</animation>
                </control>
            </control>
        </control>
    </include>

    <include name="SeasonalThemes_Animation_Santa_Right">
        <animation effect="rotate" start="-3" end="3" time="2300" tween="sine" easing="inout" pulse="true" condition="true">Conditional</animation>
        <animation effect="slide" start="0,-30" end="0,30" time="2900" tween="sine" easing="inout" pulse="true" condition="true">Conditional</animation>
    </include>

    <include name="SeasonalThemes_Animation_Santa_Left">
        <animation effect="rotate" start="8" end="-2" time="4400" tween="sine" easing="inout" pulse="true" condition="true">Conditional</animation>
        <animation effect="slide" start="0,-220" end="0,40" time="5700" tween="sine" easing="inout" pulse="true" condition="true">Conditional</animation>
    </include>

    <include name="SeasonalThemes_Animation_Surfer_Right">
        <animation effect="rotate" start="-4" end="4" time="2100" tween="cubic" easing="inout" pulse="true" condition="true">Conditional</animation>
        <animation effect="slide" start="0,-40" end="0,50" time="2700" tween="quad" easing="inout" pulse="true" condition="true">Conditional</animation>
    </include>

    <include name="SeasonalThemes_Animation_Surfer_Left">
        <animation effect="rotate" start="8" end="-6" time="3500" tween="cubic" easing="inout" pulse="true" condition="true">Conditional</animation>
        <animation effect="slide" start="0,-60" end="0,80" time="4200" tween="quad" easing="inout" pulse="true" condition="true">Conditional</animation>
    </include>

    <include name="SeasonalThemes_Animation_Witch_Right">
        <animation effect="rotate" start="10" end="-4" time="2700" tween="cubic" easing="inout" pulse="true" condition="true">Conditional</animation>
        <animation effect="slide" start="0,0" end="0,220" time="3500" tween="cubic" easing="inout" pulse="true" condition="true">Conditional</animation>
    </include>

    <include name="SeasonalThemes_Animation_Witch_Left">
        <animation effect="rotate" start="6" end="-4" time="1900" tween="cubic" easing="inout" pulse="true" condition="true">Conditional</animation>
        <animation effect="slide" start="0,-50" end="0,50" time="2100" tween="cubic" easing="inout" pulse="true" condition="true">Conditional</animation>
    </include>

</includes>
