<?xml version="1.0" encoding="UTF-8"?>
<window id="1192" type="dialog">
    <zorder>9999</zorder>
    <visible>!Window.IsVisible(startup)</visible>
    <visible>$EXP[Exp_SeasonalTheme_Active]</visible>
    <visible>$EXP[Exp_SeasonalTheme_Visible]</visible>

    <!-- With thanks to SualFred -->
    <!-- Modified by ch1re -->
    <!-- Christmas theme snow loop textures originally from skin.embuary -->

    <controls>
        <include condition="$EXP[Exp_SeasonalTheme_Winter]" content="SeasonalTheme">
            <param name="theme_dir">winter</param>
            <param name="loop_file">snow_loop.png</param>
            <param name="flyby_file">santa-claus.png</param>
            <param name="animation">Santa</param>
        </include>

        <include condition="$EXP[Exp_SeasonalTheme_Aussie]" content="SeasonalTheme">
            <param name="theme_dir">winter_aussie</param>
            <param name="loop_file">aussie_loop.png</param>
            <param name="flyby_file">santa-surfer.png</param>
            <param name="animation">Surfer</param>
        </include>

        <include condition="$EXP[Exp_SeasonalTheme_Summer]" content="SeasonalTheme">
            <param name="theme_dir">summer</param>
            <param name="loop_file">bokeh_loop.png</param>
            <param name="flyby_file">chris.png</param>
            <param name="animation">Surfer</param>
        </include>

        <include condition="$EXP[Exp_SeasonalTheme_Halloween]" content="SeasonalTheme">
            <param name="theme_dir">halloween</param>
            <param name="loop_file">bats_loop.png</param>
            <param name="flyby_file">cat-witch.png</param>
            <param name="animation">Witch</param>
        </include>
    </controls>
</window>