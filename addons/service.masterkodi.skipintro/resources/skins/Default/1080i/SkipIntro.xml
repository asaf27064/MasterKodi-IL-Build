<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="14000">
    <defaultcontrol always="true">3001</defaultcontrol>
    <coordinates>
        <system>1</system>
        <posx>0</posx>
        <posy>0</posy>
    </coordinates>
    <controls>
        <control type="group">
            <posx>1530</posx>
            <posy>876</posy>
            <width>340</width>
            <height>62</height>

            <animation effect="zoom" start="84" end="100" center="170,31" time="240" tween="cubic" easing="out">WindowOpen</animation>
            <animation effect="fade" start="0" end="100" time="240">WindowOpen</animation>
            <animation effect="zoom" start="100" end="84" center="170,31" time="180" tween="cubic" easing="in">WindowClose</animation>
            <animation effect="fade" start="100" end="0" time="180">WindowClose</animation>

            <!-- drop shadow -->
            <control type="image" id="3003">
                <posx>3</posx>
                <posy>4</posy>
                <width>334</width>
                <height>54</height>
                <aspectratio>stretch</aspectratio>
                <texture colordiffuse="66000000" border="16">rounded_rect.png</texture>
            </control>

            <!-- focus glow ring: pulses continuously so it clearly reads as a
                 selected, pressable button ("press OK to skip") -->
            <control type="image" id="3009">
                <posx>-5</posx>
                <posy>-5</posy>
                <width>344</width>
                <height>64</height>
                <aspectratio>stretch</aspectratio>
                <texture colordiffuse="FFFFFFFF" border="20">rounded_rect.png</texture>
                <animation effect="fade" start="100" end="28" time="750" loop="true" reversible="true" condition="true">Conditional</animation>
            </control>

            <!-- the pill button (base + focus textures) -->
            <control type="button" id="3001">
                <posx>0</posx>
                <posy>0</posy>
                <width>334</width>
                <height>54</height>
                <align>center</align>
                <aligny>center</aligny>
                <textoffsetx>18</textoffsetx>
                <font>font14</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <texturefocus colordiffuse="FF10D4E6" border="16">rounded_rect.png</texturefocus>
                <texturenofocus colordiffuse="FF10D4E6" border="16">rounded_rect.png</texturenofocus>
                <label>דלג על הפתיח</label>
            </control>

            <!-- skip-next icon (left) -->
            <control type="image" id="3006">
                <posx>18</posx>
                <posy>15</posy>
                <width>26</width>
                <height>26</height>
                <aspectratio>keep</aspectratio>
                <texture colordiffuse="FFFFFFFF">skip_next.png</texture>
            </control>

            <!-- countdown: faint track -->
            <control type="image" id="3007">
                <posx>16</posx>
                <posy>46</posy>
                <width>302</width>
                <height>4</height>
                <aspectratio>stretch</aspectratio>
                <texture colordiffuse="40FFFFFF" border="2">rounded_rect.png</texture>
            </control>

            <!-- countdown: draining fill (width driven from overlay.py) -->
            <control type="image" id="3008">
                <posx>16</posx>
                <posy>46</posy>
                <width>302</width>
                <height>4</height>
                <aspectratio>stretch</aspectratio>
                <texture colordiffuse="FFFFFFFF" border="2">rounded_rect.png</texture>
            </control>
        </control>
    </controls>
</window>
