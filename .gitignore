# build output
dist/
*.pyc
__pycache__/

# CI-generated merged Hebrew addons (source of truth is overlays/<id>/).
# Reconstructed by tools/apply_overlay.py at build time -- never commit them.
addons/plugin.video.gears/
addons/skin.arctic.fuse.3/
addons/skin.arctic.zephyr.2.resurrection.mod/

# secrets - NEVER commit (public repo)
.secrets/
*.keystore
*.jks
*.pem
# certifi CA bundle is ADDON CONTENT, not a secret -- without it
# certifi.where() points at a missing file and SSL verify breaks
!addons/script.module.certifi/lib/certifi/cacert.pem
*.key
secrets.json
**/tokens.json

# live/runtime databases that carry per-user state or credentials
**/addon_data/**/settings.db
**/addon_data/**/*token*
**/addon_data/**/*.session

# editor/OS junk
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Cloudflare Worker source (deployed separately; carries account/db ids) - never ship or commit
**/service.subtitles.gearsai/cloudflare/
**/.wrangler/
wrangler.toml
