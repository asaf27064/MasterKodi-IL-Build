<advancedsettings>
  <!-- MasterKodi IL: anti-buffering / smooth streaming (added 2026-07-09).
       Box has 16 GB RAM, so a big forward buffer is safe. Kodi shipped with NO
       advancedsettings.xml, so it used a tiny default cache and stalled on every
       dip in the source (52 "stream stalled" events in one The Agency episode). -->
  <network>
    <curlclienttimeout>30</curlclienttimeout>
    <curllowspeedtime>20</curllowspeedtime>  <!-- tolerate 20s of slowness before dropping a source -->
  </network>
</advancedsettings>
