{
  "build_name": "MasterKodi IL",
  "brand": "MasterKodi",
  "maintainer": "asaf27064",
  "repo": "asaf27064/MasterKodi-IL-Build",
  "release_tag": "addons-latest",
  "manifest_schema": 1,
  "config_version": 50,
  "piers": {
    "release_tag": "addons-piers",
    "manifest": "manifest-piers.json",
    "replacements": {
      "script.skinshortcuts": {
        "version": "3.0.1",
        "url": "https://mirrors.kodi.tv/addons/piers/script.skinshortcuts/script.skinshortcuts-3.0.1.zip"
      }
    },
    "notes": "Piers (Kodi 22) fleet. Same shared addon zips; skins are rebuilt from overlays-piers/ (gui 5.18 variants); 'replacements' are addons whose PIERS version differs from the source tree - CI downloads these official zips into dist/ instead of zipping our source (skinshortcuts 2.0.3 is the Omega pin, v3.0.1 is the Piers rewrite the ported Zephyr menus.xml needs). he_il needs NO replacement: the piers-repo 11.0.79 zip is byte-identical to ours (verified 2026-07-16)."
  },
  "channels": {
    "optional": [
      "plugin.video.pov",
      "plugin.video.themoviedb.helper",
      "resource.font.robotocjksc",
      "resource.images.moviecountryicons.maps",
      "resource.images.moviegenreicons.transparent",
      "resource.images.studios.coloured",
      "resource.images.studios.white",
      "resource.images.weathericons.white",
      "script.module.addon.signals",
      "script.module.infotagger",
      "script.module.jurialmunkey",
      "script.module.qrcode",
      "script.module.simpleeval",
      "script.module.simplejson",
      "script.module.six",
      "script.module.unidecode",
      "script.nimbus.helper",
      "script.skinhelper",
      "script.skinshortcuts",
      "script.skinvariables",
      "script.texturemaker",
      "service.kodi.il.firstrun",
      "skin.arctic.fuse.3",
      "skin.arctic.zephyr.2.resurrection.mod",
      "skin.nimbus"
    ],
    "gears_only": [
      "plugin.video.gears",
      "script.module.gearsscrapers",
      "script.module.cocoscrapers",
      "repository.cocoscrapers",
      "script.module.magneto",
      "repository.chainsrepo"
    ],
    "pov_only": [
      "plugin.video.pov"
    ]
  },
  "notes": "channels.optional = addons that are NOT part of every install, so the client only updates them if the user already has them. This is the two skins + their bundled deps (Arctic Fuse pulls themoviedb.helper/skinvariables/jurialmunkey/six/qrcode/fonts/resources; Nimbus pulls script.nimbus.helper) + the bootstrap-only firstrun. Marking them core would make an Estuary/Nimbus user's 'check updates' list every AF3 dependency as missing. Everything else is core and auto-updates for everyone.",
  "bundles": {
    "FenLight_Estuary.zip": {
      "repack": true,
      "state_seed": true
    },
    "Arctic_Fuse_Skin.zip": {
      "repack": true
    },
    "nimbus.zip": {
      "repack": true
    },
    "Zephyr_Skin.zip": {
      "fresh": [
        "skin.arctic.zephyr.2.resurrection.mod",
        "script.skinshortcuts",
        "script.skinhelper",
        "script.module.simplejson",
        "script.module.unidecode",
        "script.module.simpleeval",
        "script.skinvariables",
        "plugin.video.themoviedb.helper",
        "script.module.jurialmunkey",
        "script.module.infotagger",
        "script.module.addon.signals",
        "script.module.qrcode",
        "script.module.six",
        "resource.images.studios.white",
        "resource.images.moviegenreicons.transparent",
        "resource.images.moviecountryicons.maps",
        "resource.images.weathericons.white"
      ]
    },
    "POV_Estuary.zip": {
      "fresh": [
        "metadata.common.fanart.tv",
        "metadata.themoviedb.org.python",
        "metadata.tvshows.themoviedb.org.python",
        "plugin.program.autocompletion",
        "plugin.program.masterkodi.il.wizard",
        "plugin.video.pov",
        "plugin.video.themoviedb.helper",
        "repository.dendygh",
        "repository.jurialmunkey",
        "repository.kodifitzwell",
        "repository.masterkodi.il",
        "repository.peno64",
        "resource.language.he_il",
        "script.common.plugin.cache",
        "script.module.autocompletion",
        "script.module.beautifulsoup4",
        "script.module.certifi",
        "script.module.chardet",
        "script.module.idna",
        "script.module.pysubs2",
        "script.module.requests",
        "script.module.soupsieve",
        "script.module.urllib3",
        "service.masterkodi.skipintro",
        "service.subtitles.all_subs_plus",
        "service.subtitles.gearsai",
        "service.subtitles.localsubtitle",
        "service.xbmc.versioncheck",
        "skin.estuary"
      ],
      "state_seed": true,
      "seed_base": "FenLight_Estuary.zip",
      "seed_include": [
        "media/fonts",
        "media/build_icons",
        "userdata/profiles.xml",
        "userdata/RssFeeds.xml",
        "userdata/addon_data/service.subtitles.gearsai",
        "userdata/addon_data/service.subtitles.all_subs_plus",
        "userdata/addon_data/plugin.program.autocompletion"
      ]
    }
  }
}
